# ============================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================
# Copy this file to .env and configure with actual values
# DO NOT COMMIT .env file to version control

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
APP_NAME=Management Data App
APP_VERSION=1.0.0

# ============================================
# DATABASE
# ============================================
# PostgreSQL Connection
DATABASE_URL=postgresql://admin:password@localhost:5432/management_data_app
DB_HOST=localhost
DB_PORT=5432
DB_NAME=management_data_app
DB_USER=admin
DB_PASSWORD=your-secure-password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# Database backups
DB_BACKUP_ENABLED=true
DB_BACKUP_PATH=/backups/database
DB_BACKUP_RETENTION_DAYS=30

# ============================================
# REDIS CACHE
# ============================================
REDIS_URL=redis://:password@localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_TLS_ENABLED=false
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000

# Redis Sentinel (for high availability)
REDIS_SENTINEL_ENABLED=false
REDIS_SENTINEL_NODES=localhost:26379,localhost:26380,localhost:26381
REDIS_SENTINEL_NAME=mymaster

# ============================================
# AUTHENTICATION
# ============================================
# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d
JWT_ALGORITHM=HS256

# Password Hashing
BCRYPT_ROUNDS=12

# OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Session Configuration
SESSION_SECRET=your-session-secret
SESSION_TIMEOUT=3600000
SESSION_SECURE=false

# ============================================
# EMAIL CONFIGURATION
# ============================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Management Data App

# Alternative Email Providers
# Gmail
GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=your-app-password
GMAIL_REFRESH_TOKEN=your-refresh-token

# Mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mail.example.com

# ============================================
# STORAGE CONFIGURATION
# ============================================
# Local Storage
STORAGE_TYPE=local
STORAGE_PATH=/app/storage
MAX_FILE_SIZE=52428800  # 50MB

# AWS S3
AWS_ENABLED=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-bucket-name
AWS_S3_PREFIX=uploads/
AWS_CLOUDFRONT_URL=https://cdn.example.com

# GCP Cloud Storage
GCP_ENABLED=false
GCP_PROJECT_ID=your-project-id
GCP_BUCKET_NAME=your-bucket-name
GCP_CREDENTIALS_PATH=/path/to/credentials.json

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=/app/logs
LOG_RETENTION_DAYS=30
LOG_MAX_SIZE=10485760  # 10MB

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=1.0

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
# Datadog
DATADOG_ENABLED=false
DD_API_KEY=your-datadog-api-key
DD_APP_KEY=your-datadog-app-key
DD_AGENT_HOST=localhost
DD_AGENT_PORT=8125
DD_TRACE_ENABLED=true

# New Relic
NEW_RELIC_ENABLED=false
NEW_RELIC_LICENSE_KEY=your-new-relic-license-key
NEW_RELIC_APP_NAME=management-data-app

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ============================================
# SECURITY
# ============================================
# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# API Key Authentication
API_KEY_ENABLED=true
API_KEY=your-api-key

# Two-Factor Authentication
TWO_FA_ENABLED=true
TWO_FA_ISSUER=Management Data App

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
UPLOAD_ENABLED=true
UPLOAD_MAX_FILES=10
UPLOAD_ALLOWED_TYPES=pdf,doc,docx,xls,xlsx,ppt,pptx,png,jpg,jpeg,gif
UPLOAD_SCAN_VIRUS=true
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ============================================
# THIRD-PARTY INTEGRATIONS
# ============================================
# Slack Integration
SLACK_ENABLED=false
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX

# Stripe Payment Processing
STRIPE_ENABLED=false
STRIPE_PUBLIC_KEY=pk_live_xxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxx

# Twilio SMS
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_NEW_DASHBOARD=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_EXPORT_PDF=true
FEATURE_BULK_OPERATIONS=true
FEATURE_API_V2=false

# ============================================
# PERFORMANCE TUNING
# ============================================
# Query optimization
QUERY_TIMEOUT=30000  # 30 seconds
QUERY_CACHE_ENABLED=true
QUERY_CACHE_TTL=300000  # 5 minutes

# Connection pooling
DB_POOL_MIN=5
DB_POOL_MAX=20
REDIS_POOL_MIN=2
REDIS_POOL_MAX=10

# ============================================
# DEVELOPMENT ONLY
# ============================================
DEBUG=false
VERBOSE_LOGGING=false
SEED_DATABASE=false
MOCK_EMAIL=false
MOCK_SMS=false
MOCK_PAYMENTS=false

# ============================================
# KUBERNETES/DOCKER
# ============================================
KUBERNETES_ENABLED=false
DOCKER_ENABLED=true

# ============================================
# CRON JOBS
# ============================================
CRON_ENABLED=true
CRON_CLEANUP_SCHEDULE=0 2 * * *  # 2 AM daily
CRON_REPORT_GENERATION_SCHEDULE=0 8 * * *  # 8 AM daily
CRON_DATABASE_BACKUP_SCHEDULE=0 3 * * *  # 3 AM daily
CRON_CACHE_REFRESH_SCHEDULE=*/15 * * * *  # Every 15 minutes

# ============================================
# MAINTENANCE MODE
# ============================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System maintenance in progress. Please try again later.

# ============================================
# SECURITY HEADERS
# ============================================
# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_URI=https://example.report-uri.com

# Helmet.js configuration
HELMET_ENABLED=true
HELMET_CONTENT_SECURITY_POLICY=true
HELMET_HSTS=true
HELMET_HSTS_MAX_AGE=31536000

# ============================================
# ANALYTICS
# ============================================
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX-X
SEGMENT_WRITE_KEY=your-segment-write-key

# ============================================
# TIME ZONE
# ============================================
TZ=UTC
